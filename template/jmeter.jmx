            <intProp name="ActionProcessor.action">1</intProp>
            <intProp name="ActionProcessor.target">0</intProp>
            <stringProp name="ActionProcessor.duration">0</stringProp>
          </TestAction>
          <hashTree>
            <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer" testname="Sc02 Pacing Timer" enabled="true">
              <stringProp name="ConstantTimer.delay">${DELAY_TIME}</stringProp>
            </ConstantTimer>
            <hashTree/>
          </hashTree>

        </hashTree>

        <!-- =========== Fragment: Log to File (Groovy) (plan §4.10) =========== -->
        <!-- Drop-in JSR223 PostProcessor or Sampler. Writes a line to
             ${runDir}/custom/{CURRENT_SCENARIO}.log via a cached writer.
             Uses props["writer.<scenario>"] so only one FileWriter per scenario;
             tearDown closes them.
             Disabled — enable on a per-sampler basis during scenario build-out.
             Reads:  props["runDir"], vars["CURRENT_SCENARIO"], prev
             Writes: one line per invocation to the scenario log file -->
        <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Fragment: Log to File (Groovy)" enabled="false">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">def runDir = props.get(&quot;runDir&quot;)
def logger = props.get(&quot;log&quot;)
def scenario = vars.get(&quot;CURRENT_SCENARIO&quot;) ?: &quot;unknown&quot;
if (!runDir) {
    if (logger &amp;&amp; logger.warn) logger.warn(scenario, &quot;Log to File skipped: runDir is unset (GUI run)&quot;)
    return
}
def key = &quot;writer.&quot; + scenario
def w = props.get(key)
if (w == null) {
    def dir = new File(runDir, &quot;custom&quot;); dir.mkdirs()
    def f = new File(dir, scenario + &quot;.log&quot;)
    // synchronize creation to avoid racing threads double-opening
    synchronized(props) {
        w = props.get(key)
        if (w == null) {
            w = new java.io.PrintWriter(new java.io.BufferedWriter(new java.io.FileWriter(f, true)), true)
            props.put(key, w)
        }
    }
}
def ts = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss.SSS&quot;).format(new Date())
def label = prev?.getSampleLabel() ?: &quot;?&quot;
def rc = prev?.getResponseCode() ?: &quot;?&quot;
def line = ts + &quot;\t&quot; + scenario + &quot;\t&quot; + label + &quot;\t&quot; + rc
synchronized(w) { w.println(line) }
</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223PostProcessor>
        <hashTree/>

        <!-- =========== Fragment: Proxy-aware HTTP Request (plan §4.9, §4.10) =========== -->
        <!-- Example showing that root HTTP Request Defaults already supply
             proxy.host/proxy.port; individual samplers override only when
             needed (e.g., a sampler must bypass the proxy). -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Fragment: Proxy-aware HTTP Request (example)" enabled="false">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.domain"></stringProp>
          <stringProp name="HTTPSampler.port"></stringProp>
          <stringProp name="HTTPSampler.protocol"></stringProp>
          <stringProp name="HTTPSampler.contentEncoding"></stringProp>
          <stringProp name="HTTPSampler.path">/api/example</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
          <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
          <stringProp name="HTTPSampler.connect_timeout"></stringProp>
          <stringProp name="HTTPSampler.response_timeout"></stringProp>
          <stringProp name="HTTPSampler.proxyHost">${__P(proxy.host,)}</stringProp>
          <stringProp name="HTTPSampler.proxyPort">${__P(proxy.port,)}</stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="status 2xx" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="a1">2\d\d</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">Expected 2xx HTTP status</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">1</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <!-- =========== Fragment: Assertion Patterns (plan §4.10, §4.11) =========== -->
        <!-- Reference palette only. Copy individual child assertions/
             post-processors under a real sampler; do NOT enable the
             controller itself — the children have no sampler in scope
             here, and enabling runs the JSON-path assertion against
             nothing (guaranteed failure). -->
        <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="Fragment: Assertion Patterns" enabled="false"/>
        <hashTree>
          <!-- status-only -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Pattern: status == 200" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="a1">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">Expected exactly HTTP 200</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
          <!-- body-contains -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Pattern: body contains" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="a1">&quot;status&quot;:&quot;ok&quot;</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">Expected body to contain &quot;status&quot;:&quot;ok&quot;</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">16</intProp>
          </ResponseAssertion>
          <hashTree/>
          <!-- JSON path -->
          <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Pattern: JSON Path extract (supporting assertion)" enabled="true">
            <stringProp name="JSONPostProcessor.referenceNames">example_token</stringProp>
            <stringProp name="JSONPostProcessor.jsonPathExprs">$.token</stringProp>
            <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
            <stringProp name="JSONPostProcessor.defaultValues">NOT_FOUND</stringProp>
            <stringProp name="JSONPostProcessor.compute_concat">false</stringProp>
          </JSONPostProcessor>
          <hashTree/>
          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Pattern: assert JSON path result" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">def v = vars.get(&quot;example_token&quot;)
if (v == null || v == &quot;NOT_FOUND&quot; || v.isEmpty()) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;example_token not found in response JSON at $.token&quot;)
}
</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223Assertion>
          <hashTree/>
        </hashTree>

        <!-- =========== Example CSV Data Set Config (plan §4.3) =========== -->
        <!-- Disabled by default; enable inside the scenario that consumes it.
             File: data/Sc01_SomeData.csv (path is relative to jmeter.jmx's
             directory, resolved via FileServer base dir).
             Sharing=All threads, recycle=true, stopThread=false. -->
        <CSVDataSet guiclass="TestBeanGUI" testclass="CSVDataSet" testname="Fragment: CSV Data Set (Sc01_SomeData)" enabled="false">
          <stringProp name="delimiter">,</stringProp>
          <stringProp name="fileEncoding">UTF-8</stringProp>
          <stringProp name="filename">data/Sc01_SomeData.csv</stringProp>
          <boolProp name="ignoreFirstLine">true</boolProp>
          <boolProp name="quotedData">true</boolProp>
          <boolProp name="recycle">true</boolProp>
          <stringProp name="shareMode">shareMode.all</stringProp>
          <boolProp name="stopThread">false</boolProp>
          <stringProp name="variableNames">id,name,payload</stringProp>
        </CSVDataSet>
        <hashTree/>

      </hashTree>

    </hashTree>
  </hashTree>
</jmeterTestPlan>
