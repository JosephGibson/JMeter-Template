<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="JMeter Template" enabled="true">
      <stringProp name="TestPlan.comments">Reusable template. Configured via -Jprofile / -Jenv / -JprojectName; see jmeter-template-plan.md.</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
      <stringProp name="TestPlan.user_define_classpath"></stringProp>
    </TestPlan>
    <hashTree>

      <!-- ============================================================
           ROOT-LEVEL DEFAULTS (plan §4.7)
           HTTP Request Defaults bind to env-resolved props at runtime.
           Proxy fields bind to optional -Jproxy.host / -Jproxy.port.
           ============================================================ -->
      <ConfigTestElement guiclass="HttpDefaultsGui" testclass="ConfigTestElement" testname="HTTP Request Defaults" enabled="true">
        <stringProp name="HTTPSampler.domain">${__P(host,)}</stringProp>
        <stringProp name="HTTPSampler.port">${__P(port,)}</stringProp>
        <stringProp name="HTTPSampler.protocol">${__P(scheme,)}</stringProp>
        <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
        <stringProp name="HTTPSampler.path"></stringProp>
        <stringProp name="HTTPSampler.concurrentPool">6</stringProp>
        <stringProp name="HTTPSampler.proxyHost">${__P(proxy.host,)}</stringProp>
        <stringProp name="HTTPSampler.proxyPort">${__P(proxy.port,)}</stringProp>
        <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
        <stringProp name="HTTPSampler.connect_timeout">10000</stringProp>
        <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
        <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
          <collectionProp name="Arguments.arguments"/>
        </elementProp>
      </ConfigTestElement>
      <hashTree/>

      <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
        <collectionProp name="HeaderManager.headers">
          <elementProp name="User-Agent" elementType="Header">
            <stringProp name="Header.name">User-Agent</stringProp>
            <stringProp name="Header.value">JMeter-Template/${TEMPLATE_VERSION}</stringProp>
          </elementProp>
          <elementProp name="Accept" elementType="Header">
            <stringProp name="Header.name">Accept</stringProp>
            <stringProp name="Header.value">application/json, */*;q=0.8</stringProp>
          </elementProp>
          <elementProp name="Accept-Language" elementType="Header">
            <stringProp name="Header.name">Accept-Language</stringProp>
            <stringProp name="Header.value">en-US,en;q=0.9</stringProp>
          </elementProp>
        </collectionProp>
      </HeaderManager>
      <hashTree/>

      <CacheManager guiclass="CacheManagerGui" testclass="CacheManager" testname="HTTP Cache Manager" enabled="true">
        <boolProp name="clearEachIteration">true</boolProp>
        <boolProp name="useExpires">true</boolProp>
        <boolProp name="CacheManager.controlledByThread">false</boolProp>
      </CacheManager>
      <hashTree/>

      <CookieManager guiclass="CookiePanel" testclass="CookieManager" testname="HTTP Cookie Manager" enabled="true">
        <collectionProp name="CookieManager.cookies"/>
        <boolProp name="CookieManager.clearEachIteration">true</boolProp>
        <stringProp name="CookieManager.policy">standard</stringProp>
        <stringProp name="CookieManager.implementation">org.apache.jmeter.protocol.http.control.HC4CookieHandler</stringProp>
      </CookieManager>
      <hashTree/>

      <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
        <collectionProp name="Arguments.arguments">
          <elementProp name="TEMPLATE_VERSION" elementType="Argument">
            <stringProp name="Argument.name">TEMPLATE_VERSION</stringProp>
            <stringProp name="Argument.value">0.1.0</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </Arguments>
      <hashTree/>

      <!-- ============================================================
           ASSERTION FAILURE LISTENER (plan §4.6, §7.2)
           Inspects AssertionResult[] on each sample; emits one-line
           tester-friendly summary on failure only. Runs under every
           sampler (direct or transaction-wrapped).
           Reads: prev (SampleResult), props["log"], vars["CURRENT_SCENARIO"].
           Writes: nothing (pure side-effect logging).
           ============================================================ -->
      <JSR223Listener guiclass="TestBeanGUI" testclass="JSR223Listener" testname="LN01 Assertion Failure Summary" enabled="true">
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="script">def scenario = vars.get(&quot;CURRENT_SCENARIO&quot;)
if (!scenario) return
def results = prev?.getAssertionResults()
if (!results || results.length == 0) return
def logger = props.get(&quot;log&quot;)
def step = prev.getSampleLabel() ?: &quot;?&quot;
results.each { ar -&gt;
    if (ar.isFailure() || ar.isError()) {
        def expected = ar.getName() ?: &quot;assertion&quot;
        def actual = (ar.getFailureMessage() ?: &quot;failure&quot;)
        if (actual.length() &gt; 200) actual = actual.substring(0, 200) + &quot;...&quot;
        def rc = prev.getResponseCode()
        def hint = (rc &amp;&amp; !rc.equals(&quot;200&quot;)) ? (&quot;response=&quot; + rc) : null
        if (logger &amp;&amp; logger.errorSummary) {
            logger.errorSummary(scenario, step, expected, actual, hint)
        } else {
            println &quot;[ERROR] [&quot; + scenario + &quot;/&quot; + step + &quot;] Expected &quot; + expected + &quot;, got &quot; + actual
        }
    }
}</stringProp>
        <stringProp name="scriptLanguage">groovy</stringProp>
      </JSR223Listener>
      <hashTree/>

      <!-- ============================================================
           setUp Thread Group (plan §4.7)
           on_sample_error=stoptestnow so a FATAL config error aborts.
           ============================================================ -->
      <SetupThreadGroup guiclass="SetupThreadGroupGui" testclass="SetupThreadGroup" testname="setUp Thread Group" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">stoptestnow</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">1</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">1</stringProp>
        <stringProp name="ThreadGroup.ramp_time">1</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
        <stringProp name="ThreadGroup.duration"></stringProp>
        <stringProp name="ThreadGroup.delay"></stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
      </SetupThreadGroup>
      <hashTree>
        <!-- ============================================================
             SU01 Load Config + Banner (plan §4.6, §4.1, §7.1)
             Reads:  -Jprofile, -Jenv, -JprojectName, -Jmode,
                     -JrunDir, -Jproxy.host, -Jproxy.port,
                     profiles/{profile}.json, environmentVariables.json
             Writes: props[scheme,host,port,mode,projectName,envName,
                           concurrentUsers,rampUpSeconds,holdSeconds,
                           rampDownSeconds,pacingMs,thinkTimeBudgetMs,
                           estimatedIterationSec, {ScID}.weight...,
                           log.level, log.colors, log (logging module)]
                     {runDir}/effective-config.json (CLI only)
             GUI:    truncates detected jmeter.log candidates; auto-loads debug defaults
                     when -J props are unset.
             ============================================================ -->
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="SU01 Load Config + Banner" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonBuilder
import org.apache.jmeter.services.FileServer

// ---------- logging module (thread-safe) ----------
def buildLogger = { -&gt;
    def ESC = ((char) 27).toString()
    def ANSI = [reset:(ESC+&quot;[0m&quot;), cyan:(ESC+&quot;[36m&quot;), green:(ESC+&quot;[32m&quot;), yellow:(ESC+&quot;[33m&quot;), red:(ESC+&quot;[31m&quot;), bold:(ESC+&quot;[1m&quot;), dim:(ESC+&quot;[2m&quot;)]
    def lock = new Object()
    def tmplLog = org.slf4j.LoggerFactory.getLogger(&quot;tmpl&quot;)
    def colorsEnabled = { -&gt;
        def forced = props.get(&quot;log.colors&quot;)
        if (forced != null) return Boolean.parseBoolean(forced.toString())
        return System.getenv(&quot;WT_SESSION&quot;) != null
    }
    def color = { String t, String c -&gt; colorsEnabled() ? (ANSI[c] + t + ANSI.reset) : t }
    def levels = [INFO:10, WARN:20, ERROR:30]
    def levelEnabled = { String level -&gt;
        def configured = (props.get(&quot;log.level&quot;) ?: &quot;INFO&quot;).toString().trim().toUpperCase()
        def threshold = levels[configured] ?: levels.INFO
        return (levels[level] ?: levels.INFO) &gt;= threshold
    }
    def ts = { -&gt; new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(new Date()) }
    def emit = { String level, String where, String msg -&gt;
        if (!levelEnabled(level)) return
        def when = ts()
        def cleanWhere = where ?: &quot;-&quot;
        def plainLevel = level.padRight(5)
        def c = [INFO:&quot;cyan&quot;, WARN:&quot;yellow&quot;, ERROR:&quot;red&quot;][level]
        def consoleLevel = c ? color(plainLevel, c) : plainLevel
        def consoleLine = &quot;[&quot; + when + &quot;] [&quot; + consoleLevel + &quot;] [&quot; + cleanWhere + &quot;] &quot; + msg
        def logLine = &quot;[&quot; + when + &quot;] [&quot; + plainLevel + &quot;] [&quot; + cleanWhere + &quot;] &quot; + msg
        synchronized(lock) {
            println consoleLine
            switch(level) {
                case &quot;INFO&quot;:  tmplLog.info(logLine); break
                case &quot;WARN&quot;:  tmplLog.warn(logLine); break
                case &quot;ERROR&quot;: tmplLog.error(logLine); break
            }
        }
    }
    def splitLogArgs = { Object[] a -&gt;
        if (a == null || a.length == 0) return [&quot;-&quot;, &quot;&quot;]
        if (a.length == 1) return [&quot;-&quot;, a[0]?.toString()]
        return [a[0]?.toString(), a[1]?.toString()]
    }
    return [
        info:  { Object... a -&gt; def parts = splitLogArgs(a); emit(&quot;INFO&quot;, parts[0], parts[1]) },
        warn:  { Object... a -&gt; def parts = splitLogArgs(a); emit(&quot;WARN&quot;, parts[0], parts[1]) },
        error: { Object... a -&gt; def parts = splitLogArgs(a); emit(&quot;ERROR&quot;, parts[0], parts[1]) },
        banner: { String title, Map kvs -&gt;
            def keyW = (kvs.keySet().collect { it.toString().length() }.max() ?: 20)
            def valW = (kvs.values().collect { it.toString().length() }.max() ?: 20)
            def inner = 2 + keyW + 3 + valW + 2
            def boxW = Math.max(inner, title.length() + 4)
            def top = &quot;╔&quot; + (&quot;═&quot; * boxW) + &quot;╗&quot;
            def sep = &quot;╠&quot; + (&quot;═&quot; * boxW) + &quot;╣&quot;
            def bot = &quot;╚&quot; + (&quot;═&quot; * boxW) + &quot;╝&quot;
            def row = { String s -&gt; &quot;║&quot; + s.padRight(boxW) + &quot;║&quot; }
            synchronized(lock) {
                println color(top, &quot;cyan&quot;)
                println color(row(&quot;  &quot; + title), &quot;cyan&quot;)
                println color(sep, &quot;cyan&quot;)
                kvs.each { k, v -&gt;
                    def s = &quot;  &quot; + k.toString().padRight(keyW) + &quot; : &quot; + v.toString()
                    println color(row(s), &quot;cyan&quot;)
                }
                println color(bot, &quot;cyan&quot;)
            }
        },
        table: { List rows -&gt;
            if (!rows) return
            def cols = rows[0].keySet().toList()
            def widths = [:]
            cols.each { c -&gt; widths[c] = Math.max(c.toString().length(), (rows.collect { (it[c] ?: &quot;&quot;).toString().length() }.max() ?: 0)) }
            def hdr = cols.collect { it.toString().padRight(widths[it]) }.join(&quot;  &quot;)
            def dash = cols.collect { &quot;-&quot; * widths[it] }.join(&quot;  &quot;)
            synchronized(lock) {
                println hdr
                println dash
                rows.each { r -&gt; println cols.collect { (r[it] ?: &quot;&quot;).toString().padRight(widths[it]) }.join(&quot;  &quot;) }
            }
        },
        errorSummary: { String scenario, String step, String expected, String actual, String hint -&gt;
            def msg = &quot;Expected &quot; + expected + &quot;, got &quot; + actual + (hint ? (&quot; — &quot; + hint) : &quot;&quot;)
            emit(&quot;ERROR&quot;, scenario + &quot;/&quot; + step, msg)
        }
    ]
}

// ---------- detect GUI ----------
def inGui = false
try { inGui = org.apache.jmeter.gui.GuiPackage.getInstance() != null } catch (Throwable t) { inGui = false }

// ---------- base dir ----------
def baseDir = FileServer.getFileServer().getBaseDir()

// ---------- GUI: truncate jmeter.log on each run ----------
if (inGui) {
    try {
        def candidates = [
            new File(baseDir, &quot;jmeter.log&quot;),
            new File(System.getProperty(&quot;user.dir&quot;), &quot;jmeter.log&quot;)
        ]
        [&quot;jmeter.logfile&quot;,&quot;jmeterlogfile&quot;,&quot;log_file&quot;].each { k -&gt;
            def v = props.get(k)
            if (v) candidates &lt;&lt; new File(v.toString())
        }
        candidates.findAll { it != null }.unique { it.absolutePath }.each { f -&gt;
            try { new FileOutputStream(f, false).close() } catch (Throwable ignored) { /* ignore candidate */ }
        }
    } catch (Throwable t) { /* ignore */ }
}

// ---------- GUI: drop stale writer.* props from a prior run in same JVM ----------
if (inGui) {
    def staleKeys = []
    props.entrySet().each { e -&gt;
        def k = e.key
        if ((k instanceof String) &amp;&amp; k.startsWith(&quot;writer.&quot;)) staleKeys &lt;&lt; k
    }
    staleKeys.each { k -&gt;
        try {
            def w = props.get(k)
            if (w != null) {
                if (w.respondsTo(&quot;flush&quot;)) w.flush()
                if (w.respondsTo(&quot;close&quot;)) w.close()
            }
        } catch (Throwable t) { /* ignore */ }
        props.remove(k)
    }
}

// ---------- install logger into props ----------
def logger = buildLogger()
props.put(&quot;log&quot;, logger)

def fatal = { String msg -&gt;
    println &quot;[FATAL] &quot; + msg
    org.slf4j.LoggerFactory.getLogger(&quot;tmpl&quot;).error(&quot;[FATAL] &quot; + msg)
    SampleResult.setSuccessful(false)
    SampleResult.setResponseCode(&quot;FATAL&quot;)
    SampleResult.setResponseMessage(&quot;[FATAL] &quot; + msg)
    throw new RuntimeException(msg)
}

// ---------- resolve -J props; GUI defaults per plan §6.3 ----------
def profileName = props.get(&quot;profile&quot;)
def envName     = props.get(&quot;env&quot;)
def projectName = props.get(&quot;projectName&quot;)
def modeOverride= props.get(&quot;mode&quot;)
def runDir      = props.get(&quot;runDir&quot;)

if (inGui) {
    if (!profileName) profileName = &quot;debug&quot;
    if (!envName)     envName     = &quot;dev&quot;
    if (!projectName) projectName = &quot;debug&quot;
}

if (!profileName) fatal(&quot;Missing required -Jprofile&quot;)
if (!envName)     fatal(&quot;Missing required -Jenv&quot;)
if (!projectName) fatal(&quot;Missing required -JprojectName&quot;)

// ---------- environments ----------
def envFile = new File(baseDir, &quot;environmentVariables.json&quot;)
if (!envFile.exists()) fatal(&quot;Missing environmentVariables.json at &quot; + envFile.absolutePath)
def envJson = new JsonSlurper().parse(envFile)
def envs = envJson?.environments
if (!(envs instanceof Map)) fatal(&quot;environmentVariables.json: missing 'environments' map&quot;)
def env = envs[envName]
if (env == null) fatal(&quot;Unknown environment: &quot; + envName + &quot; (available: &quot; + envs.keySet().sort().join(&quot;, &quot;) + &quot;)&quot;)
[&quot;scheme&quot;,&quot;host&quot;,&quot;port&quot;].each { k -&gt;
    if (env[k] == null) fatal(&quot;environmentVariables.json[&quot; + envName + &quot;]: missing &quot; + k)
}

// ---------- profile ----------
def profileFile = new File(baseDir, &quot;profiles/&quot; + profileName + &quot;.json&quot;)
if (!profileFile.exists()) fatal(&quot;Profile file not found: &quot; + profileFile.absolutePath)
def profile = new JsonSlurper().parse(profileFile)

def requireKey = { Map m, String path -&gt;
    def parts = path.tokenize(&quot;.&quot;)
    def cursor = m
    for (p in parts) {
        if (cursor == null || !(cursor instanceof Map) || !cursor.containsKey(p)) {
            fatal(&quot;Missing profile key: &quot; + path)
        }
        cursor = cursor[p]
    }
    return cursor
}
[&quot;profileName&quot;,&quot;mode&quot;,
 &quot;load.targetSessionsPerHour&quot;,&quot;load.sessionDurationSeconds&quot;,
 &quot;load.rampUpSeconds&quot;,&quot;load.holdSeconds&quot;,&quot;load.rampDownSeconds&quot;,
 &quot;load.estimatedIterationSeconds&quot;].each { requireKey(profile, it) }

if (!(profile.scenarios instanceof List) || profile.scenarios.isEmpty()) {
    fatal(&quot;Profile 'scenarios' must be a non-empty list&quot;)
}

// ---------- override precedence: profile is base; -J overrides ----------
def mode = modeOverride ?: profile.mode
if (!(mode in [&quot;weighted&quot;,&quot;sequential&quot;])) fatal(&quot;Invalid mode: &quot; + mode)

// ---------- logging config: profile base; -Jlog.* overrides ----------
def loggingCfg = (profile.logging instanceof Map) ? profile.logging : [:]
def resolvedLogLevel = (props.get(&quot;log.level&quot;) ?: loggingCfg.level ?: &quot;INFO&quot;).toString().trim().toUpperCase()
if (!(resolvedLogLevel in [&quot;INFO&quot;,&quot;WARN&quot;,&quot;ERROR&quot;])) {
    fatal(&quot;Invalid logging.level: &quot; + resolvedLogLevel + &quot; (expected INFO|WARN|ERROR)&quot;)
}
props.put(&quot;log.level&quot;, resolvedLogLevel)

def parseBooleanConfig = { raw, String label -&gt;
    if (raw == null) return null
    def s = raw.toString().trim().toLowerCase()
    if (!(s in [&quot;true&quot;,&quot;false&quot;])) fatal(&quot;Invalid &quot; + label + &quot;: &quot; + raw + &quot; (expected true|false)&quot;)
    return s == &quot;true&quot;
}
def colorsRaw = props.get(&quot;log.colors&quot;)
if (colorsRaw == null &amp;&amp; loggingCfg.containsKey(&quot;colors&quot;)) colorsRaw = loggingCfg.colors
def resolvedLogColors = parseBooleanConfig(colorsRaw, &quot;log.colors&quot;)
if (resolvedLogColors != null) props.put(&quot;log.colors&quot;, resolvedLogColors.toString())
def effectiveLogColors = (resolvedLogColors != null) ? resolvedLogColors : (System.getenv(&quot;WT_SESSION&quot;) != null)

// ---------- derived math (closed-user model, plan §4.1) ----------
def sessSec = profile.load.sessionDurationSeconds as double
def tph     = profile.load.targetSessionsPerHour as double
def estIt   = profile.load.estimatedIterationSeconds as double

def concurrentUsers = Math.max(1, (int) Math.ceil(tph * sessSec / 3600.0d))
def pacingSec       = sessSec
def thinkBudgetSec  = Math.max(sessSec - estIt, 0.0d)

// ---------- publish props ----------
props.put(&quot;scheme&quot;,               env.scheme.toString())
props.put(&quot;host&quot;,                 env.host.toString())
props.put(&quot;port&quot;,                 env.port.toString())
props.put(&quot;mode&quot;,                 mode)
props.put(&quot;projectName&quot;,          projectName)
props.put(&quot;envName&quot;,              envName)
props.put(&quot;concurrentUsers&quot;,      concurrentUsers.toString())
props.put(&quot;rampUpSeconds&quot;,        profile.load.rampUpSeconds.toString())
props.put(&quot;holdSeconds&quot;,          profile.load.holdSeconds.toString())
props.put(&quot;rampDownSeconds&quot;,      profile.load.rampDownSeconds.toString())
props.put(&quot;pacingMs&quot;,             ((long)(pacingSec * 1000.0d)).toString())
props.put(&quot;thinkTimeBudgetMs&quot;,    ((long)(thinkBudgetSec * 1000.0d)).toString())
props.put(&quot;estimatedIterationSec&quot;, estIt.toString())

// ---------- scenario weights ----------
def runtimeWeights = [:]
profile.scenarios.each { sc -&gt;
    def id = sc.id?.toString()
    if (!id) fatal(&quot;scenarios[] entry missing 'id'&quot;)
    def w
    if (mode == &quot;sequential&quot;) {
        w = 1
    } else {
        w = (sc.weight as Integer) ?: 0
        if (w &lt;= 0) fatal(&quot;scenarios[&quot; + id + &quot;].weight must be &gt; 0 in weighted mode&quot;)
    }
    props.put(id + &quot;.weight&quot;, w.toString())
    runtimeWeights[id] = w
}

// ---------- effective-config.json (CLI only) ----------
if (!inGui &amp;&amp; runDir) {
    def rd = new File(runDir)
    rd.mkdirs()
    new File(rd, &quot;custom&quot;).mkdirs()
    def effective = [
        project: projectName,
        profile: [name: profile.profileName, description: profile.description, source: profileFile.absolutePath],
        mode: mode,
        environment: [name: envName, scheme: env.scheme, host: env.host, port: env.port],
        load: [
            targetSessionsPerHour: profile.load.targetSessionsPerHour,
            sessionDurationSeconds: profile.load.sessionDurationSeconds,
            rampUpSeconds: profile.load.rampUpSeconds,
            holdSeconds: profile.load.holdSeconds,
            rampDownSeconds: profile.load.rampDownSeconds,
            estimatedIterationSeconds: profile.load.estimatedIterationSeconds
        ],
        derived: [
            concurrentUsers: concurrentUsers,
            pacingSeconds: pacingSec,
            thinkTimeBudgetSeconds: thinkBudgetSec
        ],
        scenarios: profile.scenarios.collect { [id: it.id, weight: runtimeWeights[it.id]] },
        logging: [level: resolvedLogLevel, colors: effectiveLogColors],
        proxy: [ host: (props.get(&quot;proxy.host&quot;) ?: null), port: (props.get(&quot;proxy.port&quot;) ?: null) ]
    ]
    new File(rd, &quot;effective-config.json&quot;).text = new JsonBuilder(effective).toPrettyString()
}

// ---------- banner (CLI only) ----------
if (!inGui) {
    def scenDesc = profile.scenarios.collect {
        def w = runtimeWeights[it.id]
        (mode == &quot;weighted&quot;) ? (it.id + &quot; (&quot; + w + &quot;%)&quot;) : (it.id + &quot; (&quot; + w + &quot;)&quot;)
    }.join(&quot;, &quot;)
    def envStr = env.scheme + &quot;://&quot; + env.host + &quot;:&quot; + env.port
    def kvs = [
        &quot;Project&quot;           : projectName,
        &quot;Profile&quot;           : profile.profileName,
        &quot;Environment&quot;       : envName + &quot; (&quot; + envStr + &quot;)&quot;,
        &quot;Mode&quot;              : mode,
        &quot;Concurrent users&quot;  : concurrentUsers,
        &quot;Sessions/hour&quot;     : profile.load.targetSessionsPerHour,
        &quot;Session target (s)&quot;: profile.load.sessionDurationSeconds,
        &quot;Think time budget&quot; : thinkBudgetSec + &quot; (est. iter = &quot; + (estIt as int) + &quot;s)&quot;,
        &quot;Ramp / Hold / Ramp&quot;: profile.load.rampUpSeconds + &quot; / &quot; + profile.load.holdSeconds + &quot; / &quot; + profile.load.rampDownSeconds,
        &quot;Scenarios&quot;         : scenDesc
    ]
    logger.banner(&quot;JMeter Run Configuration&quot;, kvs)
}

SampleResult.setSuccessful(true)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setResponseMessage(&quot;setUp complete&quot;)
</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>

      <!-- ============================================================
           Main Thread Group — Ultimate Thread Group (plan §4.1)
           Schedule: start=concurrentUsers, delay=0, rampUp, hold, rampDown.
           ============================================================ -->
      <kg.apc.jmeter.threads.UltimateThreadGroup guiclass="kg.apc.jmeter.threads.UltimateThreadGroupGui" testclass="kg.apc.jmeter.threads.UltimateThreadGroup" testname="Main Thread Group (UTG)" enabled="true">
