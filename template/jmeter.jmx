      <!-- ============================================================
           tearDown Thread Group (plan §4.4, §8 phase 5)
           GUI-guarded. Closes shared writers stashed under props["writer.*"],
           emits summary. HTML report is produced by the launcher's -e -o flag.
           ============================================================ -->
      <PostThreadGroup guiclass="PostThreadGroupGui" testclass="PostThreadGroup" testname="tearDown Thread Group" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">1</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">1</stringProp>
        <stringProp name="ThreadGroup.ramp_time">1</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
        <stringProp name="ThreadGroup.duration"></stringProp>
        <stringProp name="ThreadGroup.delay"></stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
      </PostThreadGroup>
      <hashTree>
        <!-- ============================================================
             TD01 Finalize (plan §4.4, phase 5)
             Reads:  props["runDir"], props["log"], any props["writer.*"]
             Writes: closes writers; emits summary via logger.info
             GUI:    no-ops after guard.
             ============================================================ -->
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="TD01 Finalize" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">def inGui = false
try { inGui = org.apache.jmeter.gui.GuiPackage.getInstance() != null } catch (Throwable t) { inGui = false }

if (inGui) {
    SampleResult.setSuccessful(true)
    SampleResult.setResponseMessage(&quot;tearDown: GUI no-op&quot;)
    return
}

def runDir = props.get(&quot;runDir&quot;)
def logger = props.get(&quot;log&quot;)

// Close shared writers (prefix &quot;writer.&quot;) stashed by scenario fragments
def keys = []
props.entrySet().each { e -&gt;
    def k = e.key
    if ((k instanceof String) &amp;&amp; k.startsWith(&quot;writer.&quot;)) keys &lt;&lt; k
}
keys.each { k -&gt;
    try {
        def w = props.get(k)
        if (w != null) {
            if (w.respondsTo(&quot;flush&quot;)) w.flush()
            if (w.respondsTo(&quot;close&quot;)) w.close()
        }
    } catch (Throwable t) { /* ignore */ }
    props.remove(k)
}

def msg = &quot;tearDown complete — runDir=&quot; + (runDir ?: &quot;(unset)&quot;)
if (logger &amp;&amp; logger.info) logger.info(&quot;tearDown&quot;, msg) else println &quot;[INFO] &quot; + msg

SampleResult.setSuccessful(true)
SampleResult.setResponseCode(&quot;200&quot;)
SampleResult.setResponseMessage(msg)
</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>

      <!-- ============================================================
