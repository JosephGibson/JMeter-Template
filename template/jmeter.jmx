            <hashTree/>
            <!-- PostProcessor on last sampler: compute DELAY_TIME (plan §4.8) -->
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Sc01 compute DELAY_TIME" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def pacingMs = (props.get(&quot;pacingMs&quot;) ?: &quot;0&quot;).toLong()
def start = vars.getObject(&quot;iterStart&quot;) as Long
def now = System.currentTimeMillis()
def elapsed = (start != null) ? (now - start) : 0L
def remaining = pacingMs - elapsed
if (remaining &lt; 0L) {
    def overMs = -remaining
    def logger = props.get(&quot;log&quot;)
    def msg = &quot;Pacing breach: iteration &quot; + (elapsed / 1000.0d) + &quot;s, target &quot; + (pacingMs / 1000.0d) + &quot;s, overage &quot; + (overMs / 1000.0d) + &quot;s&quot;
    if (logger &amp;&amp; logger.warn) logger.warn(&quot;Sc01&quot;, msg) else println &quot;[WARN] &quot; + msg
    vars.put(&quot;DELAY_TIME&quot;, &quot;0&quot;)
} else {
    vars.put(&quot;DELAY_TIME&quot;, String.valueOf(remaining))
}
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
