        <com.blazemeter.jmeter.controller.WeightedSwitchController guiclass="com.blazemeter.jmeter.controller.WeightedSwitchControllerGui" testclass="com.blazemeter.jmeter.controller.WeightedSwitchController" testname="Scenario Selector (Weighted Switch)" enabled="true">
